# Sistema bancario com clientes, salvamento em TXT
# e saque usando cedulas de 1, 2, 5, 10, 20, 50, 100 e 200

ARQUIVO = "clientes.txt"

# ==============================
# Funções de arquivos / clientes
# ==============================

# Carrega os clientes do arquivo TXT
def carregar_clientes():
    clientes = {}
    try:
        with open(ARQUIVO, "r", encoding="utf-8") as arquivo:
            for linha in arquivo:
                nome, saldo = linha.strip().split(";")
                clientes[nome] = float(saldo)
    except FileNotFoundError:
        # Se o arquivo não existir ainda, começa com lista vazia
        pass
    return clientes

# Salva todos os cliente no arquivo TXT
def salvar_clientes(clientes):
    with open(ARQUIVO, "w", encoding="utf-8") as arquivo:
        for nome, saldo in clientes.items():
            arquivo.write(f"{nome};{saldo}\n")

# ---------------------------
# Funções de interface / menu
# ---------------------------

def mostrar_menu():
    print("\n=== Sistema Bancário ===")
    print("1 - Cadastrar cliente")
    print("2 - Depositar")
    print("3 - Sacar")
    print("4 - Consultar saldo")
    print("5 - Sair")

# ---------------------------
# Funções de operação bancária
# ---------------------------

# Cadastrar novo cliente
def cadastrar_cliente(clientes):
    nome = input("Nome do cliente: ")

    if nome in clientes:
        print("Cliente já cadastrado.")
    else:
        clientes[nome] = 0.0
        salvar_clientes(clientes)
        print(f"Cliente {nome} cadastrado com sucesso.")

# Depositar valor para um cliente
def depositar(clientes):
    nome = input("Nome do cliente: ")

    if nome not in clientes:
        print("Cliente não encontrado.")
        return

    valor = float(input("Valor do depósito: "))

    if valor > 0:
        clientes[nome] += valor
        salvar_clientes(clientes)
        print(f"Depósito realizado. Saldo de {nome}: R$ {clientes[nome]:.2f}")
    else:
        print("Valor inválido.")

# Função que calcula as cédulas para um saque
def calcular_cedulas(valor_saque):
    # Lista de cédulas disponíveis (maior para menor)
    cedulas = [200, 100, 50, 20, 10, 5, 2, 1]

    print("\nCédulas entregues:")
    valor_restante = int(valor_saque)

    for cedula in cedulas:
        quantidade = valor_restante // cedula  # Quantas cédulas dessa cabem
        if quantidade > 0:
            print(f"{quantidade} cédula(s) de R$ {cedula}")
            valor_restante -= quantidade * cedula  # Atualiza o valor restante

# Sacar valor de um cliente usando cédulas
def sacar(clientes):
    nome = input("Nome do cliente: ")

    if nome not in clientes:
        print("Cliente não encontrado.")
        return

    valor = float(input("Valor do saque: "))

    if valor <= 0:
        print("Valor inválido.")
        return

    if valor > clientes[nome]:
        print("Saldo insuficiente.")
        return

    # Aqui faz o cálculo das cédulas
    calcular_cedulas(valor)

    # Atualiza saldo do cliente
    clientes[nome] -= valor
    salvar_clientes(clientes)
    print(f"Saque realizado. Novo saldo de {nome}: R$ {clientes[nome]:.2f}")

# Consultar saldo de um cliente
def consultar_saldo(clientes):
    nome = input("Nome do cliente: ")

    if nome in clientes:
        print(f"Saldo de {nome}: R$ {clientes[nome]:.2f}")
    else:
        print("Cliente não encontrado.")

# ---------------------------
# Programa principal
# ---------------------------

clientes = carregar_clientes()

while True:
    mostrar_menu()
    opcao = input("Escolha uma opção: ")

    if opcao == "1":
        cadastrar_cliente(clientes)
    elif opcao == "2":
        depositar(clientes)
    elif opcao == "3":
        sacar(clientes)
    elif opcao == "4":
        consultar_saldo(clientes)
    elif opcao == "5":
        print("Saindo...")
        break
    else:
        print("Opção inválida.")
