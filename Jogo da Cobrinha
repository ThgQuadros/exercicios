# Importação das Bibliotecas Necessárias
import turtle
import time
import random
import os

# Tentar importar winsound para sons (Windows)
try:
    import winsound
    SOM_DISPONIVEL = True
except ImportError:
    SOM_DISPONIVEL = False

# Arquivo para salvar o recorde
ARQUIVO_RECORDE = "recorde.txt"

# Configurações de Dificuldade
DIFICULDADES = {
    "1": {"nome": "Fácil", "velocidade": 0.15, "cor_fundo": "dark green"},
    "2": {"nome": "Médio", "velocidade": 0.1, "cor_fundo": "dark blue"},
    "3": {"nome": "Difícil", "velocidade": 0.06, "cor_fundo": "dark red"},
    "4": {"nome": "Impossível", "velocidade": 0.03, "cor_fundo": "black"}
}

# Variáveis Globais
pontos = 0
recorde = 0
velocidade_jogo = 0.1
jogo_pausado = False
jogo_ativo = False
dificuldade_atual = "2"

# Função para carregar o recorde do arquivo
def carregar_recorde():
    global recorde
    try:
        if os.path.exists(ARQUIVO_RECORDE):
            with open(ARQUIVO_RECORDE, "r") as arquivo:
                recorde = int(arquivo.read().strip())
    except:
        recorde = 0

# Função para salvar o recorde no arquivo
def salvar_recorde():
    global recorde
    try:
        with open(ARQUIVO_RECORDE, "w") as arquivo:
            arquivo.write(str(recorde))
    except:
        pass

# Função para tocar som
def tocar_som(tipo):
    if not SOM_DISPONIVEL:
        return
    try:
        if tipo == "comer":
            winsound.Beep(800, 100)  # Som agudo curto
        elif tipo == "colisao":
            winsound.Beep(200, 300)  # Som grave longo
        elif tipo == "recorde":
            # Melodia de vitória
            winsound.Beep(523, 100)   # Dó
            winsound.Beep(659, 100)   # Mi
            winsound.Beep(784, 100)   # Sol
            winsound.Beep(1047, 200)  # Dó alto
        elif tipo == "inicio":
            winsound.Beep(440, 150)
            winsound.Beep(550, 150)
            winsound.Beep(660, 200)
    except:
        pass

# Carregar recorde ao iniciar
carregar_recorde()

# Configuração da Tela
tela = turtle.Screen()
tela.title("Jogo da Cobrinha - Super Edition")
tela.bgcolor("black")
tela.setup(width=600, height=650)
tela.tracer(0)

# Turtle para tela de início/game over
tela_mensagem = turtle.Turtle()
tela_mensagem.speed(0)
tela_mensagem.color("white")
tela_mensagem.penup()
tela_mensagem.hideturtle()

# Configuração da Cobrinha
cabeca = turtle.Turtle()
cabeca.speed(0)
cabeca.shape("square")
cabeca.color("lime")
cabeca.penup()
cabeca.goto(0, 0)
cabeca.direction = "stop"

# Configuração da Comida
comida = turtle.Turtle()
comida.speed(0)
comida.shape("circle")
comida.color("red")
comida.penup()
comida.goto(0, 100)

# Comida especial (bônus)
comida_especial = turtle.Turtle()
comida_especial.speed(0)
comida_especial.shape("triangle")
comida_especial.color("gold")
comida_especial.penup()
comida_especial.goto(1000, 1000)  # Escondida inicialmente
comida_especial.hideturtle()
comida_especial_ativa = False
comida_especial_tempo = 0

# Segmentos da Cobrinha
segmentos = []

# Setup da Pontuação
placar = turtle.Turtle()
placar.speed(0)
placar.color("White")
placar.penup()
placar.hideturtle()
placar.goto(0, 280)

# Turtle para informações extras
info_extra = turtle.Turtle()
info_extra.speed(0)
info_extra.color("yellow")
info_extra.penup()
info_extra.hideturtle()
info_extra.goto(0, -310)

# Função para atualizar o placar
def atualizar_placar():
    placar.clear()
    placar.write(f"Pontos: {pontos}  |  Recorde: {recorde}  |  {DIFICULDADES[dificuldade_atual]['nome']}",
                 align="center", font=("Courier", 18, "bold"))
    
#Função para atualizar informações extras
def atualizar_info():
    info_extra.clear()
    info_extra.write("P = Pausar  | R = Reiniciar  | Q = Sair",
                     align="center", font=("Courier", 12, "normal"))

# Função para mostrar tela de início
def mostrar_tela_inicio():
    global jogo_ativo
    jogo_ativo = False

    # Esconder elementos do jogo
    cabeca.hideturtle()
    comida.hideturtle()
    comida_especial.hideturtle()
    for seg in segmentos:
        seg.hideturtle()
    placar.clear()
    info_extra.clear()

    tela.bgcolor("black")
    tela_mensagem.clear()
    tela_mensagem.goto(0, 150)
    tela_mensagem.color("lime")
    tela_mensagem.write("🐍 JOGO DA COBRINHA 🐍", align="center", font=("Courier", 28, "bold"))
    
    tela_mensagem.goto(0, 80)
    tela_mensagem.color("white")
    tela_mensagem.write("Super Edition", align="center", font=("Courier", 18, "italic"))

    tela_mensagem.goto(0, 20)
    tela_mensagem.color("yellow")
    tela_mensagem.write(f"Recorde Atual: {recorde} pontos", align="center", font=("Courier", 16, "normal"))

    tela_mensagem.goto(0, -40)
    tela_mensagem.color("cyan")
    tela_mensagem.write("Escolha a Dificuldade:", align="center", font=("Courier", 16, "bold"))

    tela_mensagem.goto(0, -80)
    tela_mensagem.color("green")
    tela_mensagem.write("1 - Fácil", align="center", font=("Courier", 14, "normal"))

    tela_mensagem.goto(0, -110)
    tela_mensagem.color("blue")
    tela_mensagem.write("2 - Médio", align="center", font=("Courier", 14, "normal"))

    tela_mensagem.goto(0, -140)
    tela_mensagem.color("red")
    tela_mensagem.write("3 - Difícil", align="center", font=("Courier", 14, "normal"))

    tela_mensagem.goto(0, -170)
    tela_mensagem.color("purple")
    tela_mensagem.write("4 - Impossível", align="center", font=("Courier", 14, "normal"))

    tela_mensagem.goto(0, -220)
    tela_mensagem.color("white")
    tela_mensagem.write("Pressione o número para começar!", align="center", font=("Courier", 12, "normal"))

    tela.update()

# Função para mostrar game over
def mostrar_game_over():
    global jogo_ativo
    jogo_ativo = False

    tela_mensagem.clear()

    # Efeito visual de game over
    tela.bgcolor("dark red")
    tela.update()
    time.sleep(0.1)
    tela.bgcolor("black")
    tela.update()
    time.sleep(0.1)
    tela.bgcolor("dark red")
    tela.update()
    time.sleep(0.1)
    tela.bgcolor("black")

    tela_mensagem.goto(0, 100)
    tela_mensagem.color("red")
    tela_mensagem.write("💀 GAME OVER 💀", align="center", font=("Courier", 32, "bold"))

    tela_mensagem.goto(0, 40)
    tela_mensagem.color("white")
    tela_mensagem.write(f"Pontuação Final: {pontos}", align="center", font=("Courier", 20, "normal"))

    tela_mensagem.goto(0, 0)
    tela_mensagem.color("yellow")
    tela_mensagem.write(f"Recorde: {recorde}", align="center", font=("Courier", 18, "normal"))

    if pontos >= recorde and pontos > 0:
        tela_mensagem.goto(0, -40)
        tela_mensagem.color("gold")
        tela_mensagem.write("🏆 NOVO RECORDE! 🏆", align="center", font=("Courier", 20, "bold"))

    tela_mensagem.goto(0, -100)
    tela_mensagem.color("cyan")
    tela_mensagem.write("Pressione ESPAÇO para jogar novamente", align="center", font=("Courier", 14, "normal"))

    tela_mensagem.goto(0, -130)
    tela_mensagem.color("white")
    tela_mensagem.write("Pressione M para o Menu Principal", align="center", font=("Courier", 14, "normal"))

    tela.update()

# Função para iniciar o jogo
def iniciar_jogo(dificuldade):
    global pontos, velocidade_jogo, jogo_ativo, jogo_pausado, dificuldade_atual
    global comida_especial_ativa, comida_especial_tempo

    dificuldade_atual = dificuldade
    velocidade_jogo = DIFICULDADES[dificuldade]["velocidade"]

    tocar_som("inicio")

    # Limpar tela de início
    tela_mensagem.clear()

    # Configurar cor de fundo
    tela.bgcolor(DIFICULDADES[dificuldade]["cor_fundo"])

    # Resetar variáveis
    pontos = 0
    jogo_pausado = False
    jogo_ativo = True
    comida_especial_ativa = False
    comida_especial_tempo = 0

    # Resetar cobrinha
    cabeca.goto(0, 0)
    cabeca.direction = "stop"
    cabeca.showturtle()

    # Limpar segmentos
    for segmento in segmentos:
        segmento.hideturtle()
    segmentos.clear()

    # Resetar comida
    comida.goto(0, 100)
    comida.showturtle()

    # Esconder comida especial
    comida_especial.goto(1000, 1000)
    comida_especial.hideturtle()

    # Atualizar displays
    atualizar_placar()
    atualizar_info()

    tela.update()

# Funções para selecionar dificuldade
def selecionar_facil():
    if not jogo_ativo:
        iniciar_jogo("1")

def selecionar_medio():
    if not jogo_ativo:
        iniciar_jogo("2")

def selecionar_dificil():
    if not jogo_ativo:
        iniciar_jogo("3")

def selecionar_impossivel():
    if not jogo_ativo:
        iniciar_jogo("4")

def jogar_novamente():
    if not jogo_ativo:
        iniciar_jogo(dificuldade_atual)

def voltar_menu():
    mostrar_tela_inicio()

# Funções de controle da Cobrinha
def ir_cima():
    if jogo_ativo and not jogo_pausado and cabeca.direction != "down":
        cabeca.direction = "up"

def ir_baixo():
    if jogo_ativo and not jogo_pausado and cabeca.direction != "up":
        cabeca.direction = "down"

def ir_esquerda():
    if jogo_ativo and not jogo_pausado and cabeca.direction != "right":
        cabeca.direction = "left"

def ir_direita():
    if jogo_ativo and not jogo_pausado and cabeca.direction != "left":
        cabeca.direction = "right"

# Função para pausar o jogo
def pausar_jogo():
    global jogo_pausado
    if jogo_ativo:
        jogo_pausado = not jogo_pausado
        if jogo_pausado:
            tela_mensagem.goto(0, 0)
            tela_mensagem.color("yellow")
            tela_mensagem.write("⏸ PAUSADO ⏸", align="center", font=("Courier", 30, "bold"))
        else:
            tela_mensagem.clear()

# Função para reiniciar o jogo
def reiniciar_jogo():
    if jogo_ativo:
        iniciar_jogo(dificuldade_atual)

# Função para sair do jogo
def sair_jogo():
    salvar_recorde()
    tela.bye()

# Função de Movimento da Cobrinha
def mover():
    if cabeca.direction == "up":
        y = cabeca.ycor()
        cabeca.sety(y + 20)
    if cabeca.direction == "down":
        y = cabeca.ycor()
        cabeca.sety(y - 20)
    if cabeca.direction == "left":
        x = cabeca.xcor()
        cabeca.setx(x - 20)
    if cabeca.direction == "right":
        x = cabeca.xcor()
        cabeca.setx(x + 20)

# Função para efeito visual ao comer
def efeito_comer():
    cor_original = cabeca.color()[0]
    cabeca.color("white")
    tela.update()
    time.sleep(0.05)
    cabeca.color(cor_original)

# Função para spawnar comida especial
def spawnar_comida_especial():
    global comida_especial_ativa, comida_especial_tempo
    x = random.randint(-270, 270)
    y = random.randint(-270, 250)
    comida_especial.goto(x, y)
    comida_especial.showturtle()
    comida_especial_ativa = True
    comida_especial_tempo = time.time()

# Função para esconder comida especial
def esconder_comida_especial():
    global comida_especial_ativa
    comida_especial.goto(1000, 1000)
    comida_especial.hideturtle()
    comida_especial_ativa = False

# Função para resetar o jogo após colisão
def resetar_apos_colisao():
    global pontos, recorde

    tocar_som("colisao")

    # Verificar se é novo recorde
    if pontos > recorde:
        recorde = pontos
        salvar_recorde()
        tocar_som("recorde")

    # Esconder a cobrinha
    cabeca.hideturtle()
    for segmento in segmentos:
        segmento.hideturtle()

    # Esconder comida especial
    esconder_comida_especial()

    # Mostrar tela de game over
    mostrar_game_over()

# Configuração dos Controles do Teclado
tela.listen()
tela.onkeypress(ir_cima, "Up")
tela.onkeypress(ir_baixo, "Down")
tela.onkeypress(ir_esquerda, "Left")
tela.onkeypress(ir_direita, "Right")
tela.onkeypress(ir_cima, "w")
tela.onkeypress(ir_baixo, "s")
tela.onkeypress(ir_esquerda, "a")
tela.onkeypress(ir_direita, "d")
tela.onkeypress(pausar_jogo, "p")
tela.onkeypress(reiniciar_jogo, "r")
tela.onkeypress(sair_jogo, "q")
tela.onkeypress(selecionar_facil, "1")
tela.onkeypress(selecionar_medio, "2")
tela.onkeypress(selecionar_dificil, "3")
tela.onkeypress(selecionar_impossivel, "4")
tela.onkeypress(jogar_novamente, "space")
tela.onkeypress(voltar_menu, "m")

# Mostrar tela de início
mostrar_tela_inicio()

# Loop Principal do Jogo
while True:
    tela.update()

    if not jogo_ativo or jogo_pausado:
        time.sleep(0.1)
        continue

    # Verificação de Colisão com as Bordas
    if cabeca.xcor() > 290 or cabeca.xcor() < -290 or cabeca.ycor() > 270 or cabeca.ycor() < -290:
        resetar_apos_colisao()
        continue

    # Verificação de Colisão com a Comida Normal
    if cabeca.distance(comida) < 20:
        tocar_som("comer")
        efeito_comer()

        # Mover a Comida para uma Nova Posição
        x = random.randint(-270, 270)
        y = random.randint(-270, 250)
        comida.goto(x, y)

        # Adicionar um Novo Segmento
        novo_segmento = turtle.Turtle()
        novo_segmento.speed(0)
        novo_segmento.shape("circle")
        novo_segmento.color("green")
        novo_segmento.penup()
        segmentos.append(novo_segmento)

        # Aumentar a Pontuação
        pontos += 1

        # Verificar se é novo recorde
        if pontos > recorde:
            recorde = pontos
            salvar_recorde()

        atualizar_placar()

        # Chance de spawnar comida especial (10% de chance a cada comida)
        if not comida_especial_ativa and random.random() < 0.1:
            spawnar_comida_especial()

    # Verificação de Colisão com a Comida Especial
    if comida_especial_ativa and cabeca.distance(comida_especial) < 20:
        tocar_som("comer")
        tocar_som("comer")  # Som duplo para bônus

        # Bônus de 5 pontos
        pontos += 5

        # Verificar se é novo recorde
        if pontos > recorde:
            recorde = pontos
            salvar_recorde()

        atualizar_placar()
        esconder_comida_especial()

        # Efeito visual especial
        for _ in range(3):
            cabeca.color("gold")
            tela.update()
            time.sleep(0.05)
            cabeca.color("lime")
            tela.update()
            time.sleep(0.05)

    # Verificar tempo da comida especial (desaparece após 5 segundos)
    if comida_especial_ativa and time.time() - comida_especial_tempo > 5:
        esconder_comida_especial()

    # Mover o corpo da Cobrinha
    for index in range(len(segmentos)-1, 0, -1):
        x = segmentos[index-1].xcor()
        y = segmentos[index-1].ycor()
        segmentos[index].goto(x, y)

    # Mover o primeiro segmento para onde está a cabeça
    if len(segmentos) > 0:
        x = cabeca.xcor()
        y = cabeca.ycor()
        segmentos[0].goto(x, y)

    mover()

    # Verificação de Colisão com o Próprio Corpo
    for segmento in segmentos:
        if segmento.distance(cabeca) < 20:
            resetar_apos_colisao()
            break

    time.sleep(velocidade_jogo)

tela.mainloop()
