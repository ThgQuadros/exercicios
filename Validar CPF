def validar_cpf(cpf):
    # Remove pontos e traços, mantendo apenas os dítitos
    cpf = "".join(ch for ch in cpf if ch.isdigit())

    # Verificar se o CPF tem exatamente 11 dígitos
    if len(cpf) != 11:
        return False
    
    # Rejeita CPFs com todos os dígitos iguais, como 11111111111
    if cpf == cpf[0] * 11:
        return False
    
    # Converter os caracteres em números inteiros
    numeros = [int(digito) for digito in cpf]

    # Calcula o primeiro dígito verificador
    soma1 = 0
    for i in range(9):
        soma1 += numeros[i] * (10 - i)

    resto1 = (soma1 * 10) % 11
    if resto1 == 10:
        resto1 = 0

    # Confere se o primeiro dígito bate com o informado
    if resto1 != numeros[9]:
        return False
    
    # Calcula o segundo dígito verificador
    soma2 = 0
    for i in range(10):
        soma2 += numeros[i] * (11 - i)

    resto2 = (soma2 * 10) % 11
    if resto2 == 10:
        resto2 = 0

    # Confere se o segundo dígito bate com o informado
    if resto2 != numeros[10]:
        return False
    
    # Se passou em todas as etapas, o CPF é válido
    return True


# Exemplo de uso
cpf_teste = "555.555.555-00"
if validar_cpf(cpf_teste):
    print("CPF válido")
else:
    print("CPF inválido")
